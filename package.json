{
  "name": "careeros-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev:extension": "pnpm --filter @careeros/extension dev",
    "build:extension": "pnpm --filter @careeros/extension build",
    "build:legal-site": "echo \"Static legal site requires no build step\"",
    "build": "pnpm build:extension",
    "lint:extension": "pnpm --filter @careeros/extension lint",
    "lint:backend": "python -m ruff check apps/backend/app apps/backend/tests",
    "format:backend": "python -m ruff format apps/backend/app apps/backend/tests",
    "format:backend:check": "python -m ruff format --check apps/backend/app apps/backend/tests",
    "typecheck:extension": "pnpm --filter @careeros/extension typecheck",
    "test:backend": "python -m pytest apps/backend/tests --cov=app --cov-report=term-missing",
    "test:unit": "pnpm --filter @careeros/extension test:unit",
    "test:e2e": "playwright test",
    "backend:test": "python -m pytest apps/backend/tests",
    "lint": "pnpm lint:extension && pnpm lint:backend",
    "format": "prettier . --write && pnpm format:backend",
    "format:check": "prettier . --check && pnpm format:backend:check",
    "package:extension": "pnpm build:extension",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck:extension && pnpm test:unit && pnpm test:backend"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@eslint/js": "^9.26.0",
    "eslint": "^9.26.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.1"
  }
}
