APP_DOMAIN=api.careeros.ai

POSTGRES_DB=careeros
POSTGRES_USER=careeros
POSTGRES_PASSWORD=replace-with-strong-password

BACKEND_ENV=production
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=https://www.careeros.ai,chrome-extension://*
BACKEND_CORS_ORIGIN_REGEX=^(chrome-extension://[a-z]{32}|https://([a-z0-9-]+\.)*careeros\.ai)$
DATABASE_URL=postgresql+asyncpg://careeros:replace-with-strong-password@db:5432/careeros
REDIS_URL=redis://redis:6379/0
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-5.4-mini
OPENAI_MODEL_ADVANCED=gpt-5.5
SECRET_KEY=replace-with-64-char-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
RATE_LIMIT_REQUESTS=180
RATE_LIMIT_WINDOW_SECONDS=60
ANALYTICS_CACHE_TTL_SECONDS=300
LOG_LEVEL=INFO
ENABLE_DB_AUTO_CREATE=false
UVICORN_WORKERS=2
