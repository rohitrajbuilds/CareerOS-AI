NODE_ENV=production
VITE_API_BASE_URL=https://api.careeros.ai/api/v1
VITE_APP_ENV=production
VITE_PRIVACY_POLICY_URL=https://www.careeros.ai/privacy
VITE_SUPPORT_EMAIL=support@careeros.ai

BACKEND_ENV=production
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=https://www.careeros.ai,chrome-extension://*
BACKEND_CORS_ORIGIN_REGEX=^(chrome-extension://.*|https://(www\\.)?careeros\\.ai)$
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/careeros
REDIS_URL=redis://default:PASSWORD@HOST:6379/0
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-5.4-mini
OPENAI_MODEL_ADVANCED=gpt-5.5
SECRET_KEY=replace-with-64-char-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
RATE_LIMIT_REQUESTS=180
RATE_LIMIT_WINDOW_SECONDS=60
ANALYTICS_CACHE_TTL_SECONDS=300
LOG_LEVEL=INFO
ENABLE_DB_AUTO_CREATE=false
UVICORN_WORKERS=2
