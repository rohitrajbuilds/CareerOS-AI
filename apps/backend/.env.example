BACKEND_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000,chrome-extension://*
BACKEND_CORS_ORIGIN_REGEX=^(chrome-extension://.*|https://.*|http://localhost(:\\d+)?)$
DATABASE_URL=postgresql+asyncpg://careeros:careeros@db:5432/careeros
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-5.4-mini
OPENAI_MODEL_ADVANCED=gpt-5.5
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
ANALYTICS_CACHE_TTL_SECONDS=120
LOG_LEVEL=INFO
ENABLE_DB_AUTO_CREATE=true
